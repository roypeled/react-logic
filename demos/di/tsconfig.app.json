{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["dom"],
    "types": ["node", "@nx/react/typings/cssmodule.d.ts", "@nx/react/typings/image.d.ts", "vite/client"],
    "rootDir": "src"
  },
  "exclude": ["out-tsc", "dist", "src/**/*.spec.ts", "src/**/*.spec.tsx", "vite.config.ts", "vite.config.mts", "eslint.config.mjs"],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [{ "path": "../../libs/react-logic/tsconfig.lib.json" }]
}
